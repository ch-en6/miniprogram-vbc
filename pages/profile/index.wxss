/* pages/profile/index.wxss — 个人中心 */

.page-pad {
  min-height: 100vh;
  background: #f5f6f8;
  padding-bottom: 40rpx;
}

.btn-row {
  margin: 24rpx;
}

/* ═══ 员工信息卡片 ═══ */
.emp-card {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.emp-card-header {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx 20rpx;
  background: linear-gradient(135deg, #1989fa, #4da6ff);
}

.emp-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.emp-avatar-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.emp-header-info {
  flex: 1;
  min-width: 0;
}

.emp-name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.emp-dept {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

.emp-role-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  padding: 4rpx 16rpx;
}

.emp-card-body {
  padding: 20rpx 28rpx 24rpx;
}

.emp-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.emp-info-row:last-child {
  border-bottom: none;
}

.emp-label {
  font-size: 28rpx;
  color: #8c9bad;
}

.emp-value {
  font-size: 28rpx;
  color: #333;
}

.emp-phone-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rebind-link {
  font-size: 24rpx;
  color: #1989fa;
  padding: 4rpx 14rpx;
  border: 1px solid #1989fa;
  border-radius: 8rpx;
  line-height: 1.4;
}

/* ═══ 工牌二维码卡片 ═══ */
.qr-card {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  padding: 28rpx;
}

.qr-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 24rpx;
  text-align: center;
}

.qr-card-body {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-wrapper {
  position: relative;
  width: 360rpx;
  height: 360rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  overflow: hidden;
}

.qr-canvas {
  width: 360rpx;
  height: 360rpx;
}

/* 停用状态：半透明遮罩 + 红色文字覆盖在二维码上 */
.qr-disabled-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-disabled-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #ee0a24;
  text-align: center;
  padding: 12rpx 24rpx;
  border: 4rpx solid #ee0a24;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.9);
  transform: rotate(-15deg);
}

.qr-emp-info {
  margin-top: 20rpx;
  text-align: center;
}

.qr-emp-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.qr-emp-no {
  display: block;
  font-size: 24rpx;
  color: #8c9bad;
}

/* 卡片底部停用提示 */
.qr-card-disabled-tip {
  margin-top: 20rpx;
  text-align: center;
  padding: 12rpx 0 4rpx;
  border-top: 1rpx solid #f0f0f0;
}

.disabled-tip-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ee0a24;
}

/* ═══ 工作台切换 ═══ */
.mini-card {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.workspace-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: nowrap;
  margin-top: 20rpx;
  align-items: stretch;
}

.workspace-tags .ws-btn {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 24rpx;
  border-radius: 8rpx;
  padding: 12rpx 0;
  line-height: 1.3;
  box-sizing: border-box;
  white-space: normal;
  word-break: break-all;
}

.ws-btn-primary {
  background: #1989fa;
  color: #fff;
  border: 1px solid #1989fa;
}

.ws-btn-plain {
  background: #fff;
  color: #1989fa;
  border: 1px solid #1989fa;
}

.ws-btn-danger {
  background: #fff;
  color: #ee0a24;
  border: 1px solid #ee0a24;
}

/* ═══ 换绑弹窗 ═══ */
.phone-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(17, 24, 39, 0.42);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
}

.phone-modal-card {
  width: 100%;
  max-height: 92%;
  overflow: auto;
  background: #fff;
  border-radius: 36rpx;
  padding: 24rpx;
  box-shadow: 0 36rpx 80rpx rgba(17, 24, 39, 0.24);
}

.modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  font-weight: 700;
}

.modal-title {
  font-size: 30rpx;
}

.rebind-tip {
  margin-bottom: 20rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.sms-btn-mini {
  flex-shrink: 0;
  min-width: 180rpx !important;
  max-width: 200rpx !important;
}

/* ═══ 订阅消息 ═══ */
.subscribe-status {
  font-size: 24rpx;
  color: #969799;
  margin-right: 8rpx;
}
.subscribe-status.subscribed {
  color: #07c160;
}
