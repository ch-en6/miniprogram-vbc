<!-- pages/index/index.wxml — 对齐原型 EmployeeHome -->
<view class="page-pad">
  <!-- Hero -->
  <view class="hero">
    <view class="hero-title">企业食堂报餐</view>
    <view class="hero-sub">{{ heroSub }}</view>
  </view>

  <!-- 公告 -->
  <van-notice-bar
    wx:if="{{ announcement }}"
    left-icon="volume-o"
    text="{{ announcement }}"
    custom-class="notice-bar"
  />

  <!-- 今日报餐状态 -->
  <view class="section-title">今日报餐状态</view>
  <view class="mini-card">
    <view class="meal-row" wx:for="{{ mealRows }}" wx:key="key">
      <view class="meal-name">{{ item.name }}</view>
      <view class="meal-desc">{{ item.desc }}</view>
      <van-tag type="{{ item.tagType }}">{{ item.tagText }}</van-tag>
    </view>
  </view>

  <!-- 本月报餐总计 -->
  <view class="mini-card">
    <view class="title-line">本月报餐总计 <small>截至昨日，不含今日</small></view>
    <view class="stat-grid">
      <view class="stat">
        <text class="stat-num">{{ monthStat.breakfast }}</text>
        <text class="stat-label">早餐</text>
      </view>
      <view class="stat">
        <text class="stat-num">{{ monthStat.lunch }}</text>
        <text class="stat-label">午餐</text>
      </view>
      <view class="stat">
        <text class="stat-num">{{ monthStat.dinner }}</text>
        <text class="stat-label">晚餐</text>
      </view>
    </view>
  </view>

  <!-- 立即报餐 -->
  <van-button type="primary" block round icon="edit" bindtap="goBook">立即报餐</van-button>

  <!-- 工作台入口（仅管理员角色显示） -->
  <view class="mini-card" wx:if="{{ hasWorkbench }}" style="margin-top: 24rpx;">
    <view class="section-title" style="margin-top: 0;">工作台入口</view>
    <view class="workspace-tags">
      <view wx:if="{{ isDeptAdmin }}" class="ws-btn ws-btn-plain" bindtap="goWorkbench">进入部门管理员工作台</view>
      <view wx:if="{{ isSysAdmin }}" class="ws-btn ws-btn-plain" bindtap="goWorkbench">进入系统管理员工作台</view>
      <view wx:if="{{ isKitchen }}" class="ws-btn ws-btn-plain" bindtap="goWorkbench">进入食堂工作台</view>
    </view>
  </view>
</view>
