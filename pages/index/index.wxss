/* pages/index/index.wxss — 首页样式（对齐原型 EmployeeHome）
 * 卡片边距标准统一：padding ≡ 24rpx，margin-horizontal ≡ 32rpx，border-radius ≡ 24~28rpx
 */

/* notice-bar 通知条（全宽，与 hero 同宽） */
.notice-bar {
  margin: 0 0 20rpx;
}

/* ═══ 报餐状态两栏布局 ═══ */
.meal-dual {
  display: flex;
  gap: 20rpx;
  margin: 20rpx 0;
}
.meal-col {
  flex: 1;
  min-width: 0;
  margin: 0;
}
.meal-col-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 16rpx;
}
.meal-col-date {
  font-size: 20rpx;
  font-weight: 400;
  color: #9ca3af;
  margin-left: 8rpx;
}
.meal-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1px solid #f0f1f3;
}
.meal-item:last-child {
  border-bottom: 0;
}
.meal-item-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.workspace-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: nowrap;
  margin-top: 20rpx;
  align-items: stretch;
}

/* 工作台按钮基础样式（与 profile 页一致） */
.workspace-tags .ws-btn {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 24rpx;
  border-radius: 8rpx;
  padding: 12rpx 0;
  line-height: 1.3;
  box-sizing: border-box;
  white-space: normal;
  word-break: break-all;
}

.workspace-tags .ws-btn-plain {
  background: #fff;
  color: #1989fa;
  border: 1px solid #1989fa;
}
