<view class="login-page">
  <!-- Logo 区域 -->
  <view class="logo-area">
    <view class="logo-icon">餐</view>
    <text class="app-name">企业报餐</text>
    <text class="app-slogan">简单高效的企业用餐管理</text>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <text class="login-title">欢迎使用</text>
    <text class="login-desc">使用微信授权手机号，快速完成登录</text>

    <!-- 微信授权手机号登录（主要方式） -->
    <button
      class="btn-wechat-login"
      open-type="getPhoneNumber"
      bindgetphonenumber="onGetPhoneNumber"
      loading="{{loading}}"
      disabled="{{loading}}"
    >{{ loading ? '登录中...' : '微信授权手机号登录' }}</button>

    <!-- 分割线 -->
    <view class="divider">
      <view class="divider-line"></view>
      <text class="divider-text">或</text>
      <view class="divider-line"></view>
    </view>

    <!-- 手机号+验证码登录（备选） -->
    <view class="sms-login-area" wx:if="{{!showSmsLogin}}">
      <text class="sms-toggle" bindtap="toggleSmsLogin">手机号 + 验证码登录</text>
    </view>

    <view class="sms-form" wx:if="{{showSmsLogin}}">
      <van-field
        value="{{ phone }}"
        label="手机号"
        placeholder="请输入手机号"
        type="number"
        maxlength="11"
        bind:change="onPhoneInput"
      />
      <view class="sms-row">
        <van-field
          value="{{ smsCode }}"
          label="验证码"
          placeholder="6位验证码"
          type="number"
          maxlength="6"
          bind:change="onSmsInput"
        />
        <button
          class="btn-sms"
          size="mini"
          disabled="{{smsCooldown > 0 || phone.length !== 11}}"
          bindtap="sendSmsCode"
        >
          {{ smsCooldown > 0 ? smsCooldown + 's' : '发送验证码' }}
        </button>
      </view>
      <van-button
        type="primary"
        block
        round
        loading="{{ loading }}"
        disabled="{{ loading || phone.length !== 11 || smsCode.length !== 6 }}"
        bindtap="onSmsLogin"
        custom-class="btn-sms-submit"
      >立即登录</van-button>
    </view>
  </view>

  <!-- 隐私提示 -->
  <view class="privacy-tip">
    <text>登录即表示同意</text>
    <text class="privacy-link" bindtap="showPrivacy">《用户隐私协议》</text>
  </view>

  <!-- Toast -->
  <van-toast id="van-toast" />
</view>
